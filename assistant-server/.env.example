# 复制为 .env 后填写（.env 已被 .gitignore 忽略，不会提交）

# 对话模型（OpenAI）
OPENAI_API_KEY=sk-xxxx
# 可选：走中转/代理时设置
# OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-5.4

# 语音识别 + 合成（火山引擎豆包语音）—— 两种鉴权二选一：
# 新版控制台：控制台 > API Key管理
DOUBAO_API_KEY=
# 旧版控制台：应用管理里的 APP ID + Access Token（填了这两个就优先用旧版双头鉴权）
# DOUBAO_APP_ID=
# DOUBAO_ACCESS_TOKEN=
# TTS 音色ID（豆包语音合成模型2.0 的音色，控制台音色列表选取）。
# ★必填：不传音色时豆包按「纯文本生成」模式把文本当提示词，可能不是逐字朗读
DOUBAO_TTS_SPEAKER=
# 可选：ASR 资源ID，默认 volc.bigasr.sauc.duration（流式识别1.0小时版）；
# 用 2.0 换成 volc.seedasr.sauc.duration
# DOUBAO_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# 服务端口（手机 App 里配置 http://<电脑局域网IP>:<PORT>）
PORT=8300

# 可选：Home Assistant MCP（Streamable HTTP 地址）。配置后机器人可语音控制智能家居
# HA_MCP_URL=http://<HA-MCP地址>:<端口>/<路径>
# 可选：覆盖暴露给模型的 HA 工具白名单（逗号分隔，默认见 ha-mcp.js）
# HA_MCP_TOOLS=ha_search,ha_get_overview,ha_get_state,ha_get_entity,ha_call_service,ha_bulk_control

# 可选：唤醒提示音文本（机器人被唤醒后先播这一句，默认「我在听」）
# PROMPT_TEXT=我在听

# 可选：覆盖系统提示词
# SYSTEM_PROMPT=你是桌面机器人 StackChan……
